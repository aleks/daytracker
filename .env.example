# Server
DAYTRACKER_PORT=8080
DAYTRACKER_DB_PATH=./daytracker.db

# Worker
DAYTRACKER_SYNC_INTERVAL=15m
DAYTRACKER_STATUS_REFRESH_INTERVAL=5m
DAYTRACKER_BACKFILL_DAYS=14
# IANA timezone for determining "today" — set when the server runs in a different
# timezone than your working hours (e.g. America/New_York, Europe/Berlin)
# DAYTRACKER_TIMEZONE=UTC

# Backup — optional absolute path; if set, daily markdown snapshots are written
# to <dir>/YYYY/MM/DD.md, suitable for checking into a git repository.
# DAYTRACKER_BACKUP_DIR=/absolute/path/to/backup

# GitHub connector — requires a personal access token with repo and read:user scopes
# Create one at https://github.com/settings/tokens
DAYTRACKER_GITHUB_TOKEN=

# Jira connector
DAYTRACKER_JIRA_BASE_URL=https://your-org.atlassian.net
DAYTRACKER_JIRA_EMAIL=you@example.com
DAYTRACKER_JIRA_TOKEN=

# Confluence connector
DAYTRACKER_CONFLUENCE_BASE_URL=https://your-org.atlassian.net
DAYTRACKER_CONFLUENCE_EMAIL=you@example.com
DAYTRACKER_CONFLUENCE_TOKEN=
